{
  "expo": {
    "name": "PALOGPTracker",
    "slug": "palogptracker",
    "version": "1.0.5",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.palow.palogptracker"
    },
    "android": {
      "package": "com.palow.palogptracker",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyARHyNyziEixlkfFZjqF6G1WE3NKcBl52E"
        }
      },
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "位置情報を使ってルートを記録します。",
          "locationAlwaysPermission": "バックグラウンドでルートを記録するために常に位置情報を使用します。",
          "locationWhenInUsePermission": "ルート記録中に位置情報を使用します。"
        }
      ]
    ],
    "scheme": "palogptracker"
  }
}
